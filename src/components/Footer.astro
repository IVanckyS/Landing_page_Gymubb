---
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden">
  <div class="h-px" style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), rgba(139,92,246,0.4), transparent);"></div>

  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(59,130,246,0.04) 0%, transparent 70%);">
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <div class="flex items-center gap-2">
          <svg width="20" height="20" viewBox="0 0 28 28" fill="none" class="text-blue-500">
            <rect x="2" y="11" width="5" height="6" rx="1.5" fill="currentColor" opacity="0.7"/>
            <rect x="21" y="11" width="5" height="6" rx="1.5" fill="currentColor" opacity="0.7"/>
            <rect x="7" y="8" width="4" height="12" rx="1.5" fill="currentColor"/>
            <rect x="17" y="8" width="4" height="12" rx="1.5" fill="currentColor"/>
            <rect x="11" y="12" width="6" height="4" rx="1" fill="currentColor"/>
          </svg>
          <span class="font-black text-base">
            <span class="text-white">Gym</span><span class="gradient-text">UBB</span>
          </span>
        </div>
        <span class="text-slate-600 text-sm hidden sm:inline">·</span>
        <span class="text-slate-500 text-sm">
          © {year} Proyecto de Tesis · Universidad del Bío-Bío
        </span>
      </div>

      <div class="flex items-center gap-6 text-sm text-slate-500">
        <a href="#hero" class="hover:text-slate-300 transition-colors duration-200">Inicio</a>
        <a href="#features" class="hover:text-slate-300 transition-colors duration-200">Features</a>
        <a
          href="https://github.com/IVanckyS/mockup_gymubb.git"
          target="_blank"
          rel="noopener"
          class="hover:text-blue-400 transition-colors duration-200 flex items-center gap-1.5"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
