---
const techs = [
  {
    name: 'Flutter',
    role: 'App móvil',
    glow: '#54C5F8',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><path d="M13.5 27.5L4 18l2.5-2.5L16 25l-2.5 2.5z" fill="#54C5F8"/><path d="M4 18l9.5-9.5h5L9 18l-5 0z" fill="#54C5F8"/><path d="M18.5 8.5L28 18l-5 5-4.5-4.5L25 18l-6.5-6.5V8.5z" fill="#01579B"/><path d="M13.5 27.5L18.5 23l4.5 4.5-4.5 4.5-5-4.5z" fill="#29B6F6"/></svg>`,
  },
  {
    name: 'Dart',
    role: 'Backend + App',
    glow: '#0175C2',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><path d="M6 20.5L8 8l12-4 6 6-14 2-2 12-4-3.5z" fill="#0175C2"/><path d="M28 12l-2 12-12 4-6-6 14-2 2-12 4 4z" fill="#13B9FD"/><path d="M8 8l-2 12.5 4 3.5 2-12 12-2-4.5-6L8 8z" fill="#01579B" opacity=".7"/></svg>`,
  },
  {
    name: 'Shelf',
    role: 'HTTP Backend',
    glow: '#0175C2',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><rect x="4" y="24" width="24" height="4" rx="2" fill="#0175C2"/><rect x="4" y="14" width="24" height="4" rx="2" fill="#13B9FD" opacity=".8"/><rect x="4" y="4"  width="24" height="4" rx="2" fill="#0175C2" opacity=".6"/><rect x="8"  y="8"  width="2" height="6" rx="1" fill="#13B9FD"/><rect x="22" y="8"  width="2" height="6" rx="1" fill="#13B9FD"/><rect x="8"  y="18" width="2" height="6" rx="1" fill="#0175C2"/><rect x="22" y="18" width="2" height="6" rx="1" fill="#0175C2"/></svg>`,
  },
  {
    name: 'PostgreSQL',
    role: 'Base de datos',
    glow: '#336791',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><ellipse cx="16" cy="8" rx="10" ry="4" stroke="#336791" stroke-width="2"/><path d="M6 8v8c0 2.2 4.5 4 10 4s10-1.8 10-4V8" stroke="#336791" stroke-width="2"/><path d="M6 16v8c0 2.2 4.5 4 10 4s10-1.8 10-4v-8" stroke="#4a90d9" stroke-width="2"/><path d="M26 12c2 0 3.5.8 3.5 2v8c0 1.2-1.5 2-3.5 2" stroke="#336791" stroke-width="1.5"/></svg>`,
  },
  {
    name: 'Docker',
    role: 'Infraestructura',
    glow: '#2496ED',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><rect x="4"  y="14" width="5" height="4" rx="1" stroke="#2496ED" stroke-width="1.5"/><rect x="10" y="14" width="5" height="4" rx="1" stroke="#2496ED" stroke-width="1.5"/><rect x="16" y="14" width="5" height="4" rx="1" stroke="#2496ED" stroke-width="1.5"/><rect x="10" y="9"  width="5" height="4" rx="1" stroke="#2496ED" stroke-width="1.5"/><rect x="16" y="9"  width="5" height="4" rx="1" stroke="#2496ED" stroke-width="1.5"/><path d="M4 18c0 4.4 5.4 8 12 8s14-3.6 14-8" stroke="#2496ED" stroke-width="1.5"/><path d="M27 16c1.6-.4 3 .4 3 2" stroke="#2496ED" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    name: 'GitHub Actions',
    role: 'CI/CD',
    glow: '#2ea44f',
    icon: `<svg viewBox="0 0 32 32" fill="none" class="w-8 h-8"><circle cx="16" cy="16" r="12" stroke="#2ea44f" stroke-width="2"/><circle cx="16" cy="16" r="4"  fill="#2ea44f"/><path d="M16 4v4M16 24v4M4 16h4M24 16h4" stroke="#2ea44f" stroke-width="2" stroke-linecap="round"/><circle cx="16" cy="16" r="8" stroke="#2ea44f" stroke-width="1" stroke-dasharray="3 3" opacity=".5"/></svg>`,
  },
];
---

<section id="stack" class="py-28 px-6 relative">
  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(59,130,246,0.05) 0%, transparent 70%);">
  </div>

  <div class="max-w-5xl mx-auto relative z-10">

    <div class="mb-16 reveal text-center">
      <div class="section-line w-16 mb-6 mx-auto"></div>
      <h2 class="font-black text-white mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">
        Construido con
        <span class="gradient-text">tecnología robusta.</span>
      </h2>
      <p class="text-slate-400 max-w-lg mx-auto" style="font-size: 1.05rem;">
        Stack moderno y probado en producción, desde el cliente hasta la base de datos.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {techs.map((t, i) => (
        <div
          class={`reveal stagger-${i + 1} tech-badge gradient-border flex flex-col items-center gap-3 py-6 px-4 text-center`}
          style={`--glow: ${t.glow};`}
          onmouseenter={`this.style.boxShadow='0 0 25px ${t.glow}44, 0 0 50px ${t.glow}22'`}
          onmouseleave={`this.style.boxShadow='none'`}
        >
          <div class="relative">
            <div class="absolute inset-0 blur-lg rounded-full opacity-50"
              style={`background: ${t.glow};`}></div>
            <div class="relative" set:html={t.icon} />
          </div>
          <div>
            <div class="text-white font-bold text-sm">{t.name}</div>
            <div class="text-slate-500 text-xs mt-0.5">{t.role}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 reveal gradient-border p-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="p-3 rounded-xl flex-shrink-0" style="background: rgba(59,130,246,0.1);">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-blue-400">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="text-white font-bold text-sm mb-1">Arquitectura cliente-servidor con Docker</div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Backend en Dart/Shelf con PostgreSQL, containerizado con Docker Compose.
            App móvil Flutter para Android e iOS, comunicación via REST API con autenticación JWT.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
